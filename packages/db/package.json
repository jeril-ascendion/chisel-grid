    "pg": "^8.11.0",
    "@chiselgrid/types": "workspace:*"
  },
  "devDependencies": {
    "drizzle-kit": "^0.22.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "@types/pg": "^8.11.0",
    "@chiselgrid/config": "workspace:*"
  }
}
