{
  "name": "@chiselgrid/db",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrations/run.ts",
    "db:seed": "tsx src/seeds/run.ts",
    "db:rls": "tsx src/rls/apply-rls.ts",
    "db:rls:verify": "tsx src/rls/verify-rls.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1025.0",
    "@chiselgrid/types": "workspace:*",
    "drizzle-orm": "^0.31.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@chiselgrid/config": "workspace:*",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.22.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
