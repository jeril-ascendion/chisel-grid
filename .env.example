# Copy to .env.local and fill in values — never commit .env.local

# Database (Aurora Serverless v2)
DATABASE_URL=postgresql://user:pass@cluster.region.rds.amazonaws.com:5432/chiselgrid

# AWS
AWS_REGION=ap-southeast-1
AWS_BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514
AWS_S3_BUCKET=chiselgrid-media-dev
AWS_CLOUDFRONT_DOMAIN=xxxxx.cloudfront.net

# Auth (Cognito)
COGNITO_USER_POOL_ID=ap-southeast-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
NEXTAUTH_SECRET=replace-with-32-char-random-string
NEXTAUTH_URL=http://localhost:3000

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
